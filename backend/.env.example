# Copy this file to .env and fill in your values
# Never commit .env to git

# Get this from your Gumroad product URL
# e.g. gumroad.com/l/architects-blueprint -> permalink is "architects-blueprint"
GUMROAD_PERMALINK=architects-blueprint

# Secret used to sign JWT tokens — generate a strong one with:
# node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=change-this-to-a-long-random-hex-string

# Set to "production" on Vercel (Vercel sets this automatically)
NODE_ENV=development

# Port for local dev (Vercel ignores this)
PORT=3000
