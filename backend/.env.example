# Copy this file to .env and fill in your values
# Never commit .env to git

# Get this from your Gumroad product URL
# e.g. gumroad.com/l/architects-blueprint → permalink is "architects-blueprint"
GUMROAD_PERMALINK=architects-blueprint

# Random secret string for encrypting sessions — generate one at:
# https://randomkeygen.com (use "CodeIgniter Encryption Keys")
SESSION_SECRET=change-this-to-a-long-random-string

# Set to "production" on Railway
NODE_ENV=development

# Port (Railway sets this automatically — don't change)
PORT=3000
